# ============================================
# Imagine Engine 管理后台 - 环境变量配置
# ============================================
#
# 使用说明：
# 1. 复制此文件为 .env.local
# 2. 填写下面的配置值
# 3. 不要将 .env.local 提交到 Git
#
# ============================================

# ============================================
# 必需配置 - Supabase 数据库
# ============================================
# 从 Supabase Dashboard -> Settings -> API 获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# 可选配置 - 管理员账号
# ============================================
# 默认管理员邮箱（用于初始化脚本）
ADMIN_EMAIL=admin@imagine-engine.com

# 默认管理员密码（用于初始化脚本）
# ⚠️ 首次登录后请立即修改密码！
ADMIN_PASSWORD=admin123456

# ============================================
# 可选配置 - Microsoft Clarity 用户行为分析
# ============================================
# 从 https://clarity.microsoft.com/ 获取项目ID
# 用于用户行为追踪、热力图、会话录制
NEXT_PUBLIC_CLARITY_ID=your-clarity-project-id

# ============================================
# 自动配置 - 无需手动设置
# ============================================
# NODE_ENV=development  # Next.js 自动设置
